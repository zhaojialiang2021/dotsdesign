{
  "$description": "Dots 字体体系。富文本遵循点点 AI 富文本渲染规范；对话 UI 遵循 Dots 对话规范。",
  "font": {
    "family": {
      "$value": "'PingFang SC', -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif",
      "$type": "fontFamily",
      "$description": "唯一字体栈"
    }
  },
  "typography": {
    "rich-h1": {
      "$value": { "fontSize": "20pt", "fontWeight": 600, "lineHeight": "34pt", "letterSpacing": "0.06em" },
      "$type": "typography",
      "$description": "富文本总标题 H1"
    },
    "rich-h2": {
      "$value": { "fontSize": "18pt", "fontWeight": 600, "lineHeight": "31pt", "letterSpacing": "0.06em" },
      "$type": "typography",
      "$description": "富文本一级模块标题 H2"
    },
    "rich-h3": {
      "$value": { "fontSize": "17pt", "fontWeight": 600, "lineHeight": "29pt", "letterSpacing": "0.06em" },
      "$type": "typography",
      "$description": "富文本二级模块标题 H3"
    },
    "rich-h4": {
      "$value": { "fontSize": "16pt", "fontWeight": 600, "lineHeight": "27pt", "letterSpacing": "0.06em" },
      "$type": "typography",
      "$description": "富文本三级模块标题 H4"
    },
    "rich-paragraph": {
      "$value": { "fontSize": "16pt", "fontWeight": 400, "lineHeight": "27pt", "letterSpacing": "0.06em" },
      "$type": "typography",
      "$description": "富文本正文段落、列表、引用"
    },
    "rich-table": {
      "$value": { "fontSize": "14pt", "fontWeight": 400, "lineHeight": "24pt", "letterSpacing": "0.06em" },
      "$type": "typography",
      "$description": "富文本表格内容"
    },
    "dialog-bubble": {
      "$value": { "fontSize": "16px", "fontWeight": 400, "lineHeight": "1.69em", "letterSpacing": "0.06em" },
      "$type": "typography",
      "$description": "对话气泡正文"
    },
    "dialog-input": {
      "$value": { "fontSize": "16px", "fontWeight": 400, "lineHeight": "48px", "letterSpacing": "0.02em" },
      "$type": "typography",
      "$description": "输入框文字"
    },
    "dialog-time": {
      "$value": { "fontSize": "13px", "fontWeight": 400, "lineHeight": "18px" },
      "$type": "typography",
      "$description": "对话时间标签"
    },
    "community-card-title": {
      "$value": { "fontSize": "14px", "fontWeight": 500, "lineHeight": "20px" },
      "$type": "typography",
      "$description": "社区卡片标题，最多两行"
    },
    "support": {
      "$value": { "fontSize": "12px", "fontWeight": 400, "lineHeight": "17px" },
      "$type": "typography",
      "$description": "辅助文字"
    },
    "headline-h1": {
      "$value": { "fontSize": "20pt", "fontWeight": 600, "lineHeight": "34pt" },
      "$type": "typography",
      "$description": "兼容旧文档：映射到 Rich H1"
    },
    "headline-h2": {
      "$value": { "fontSize": "18pt", "fontWeight": 600, "lineHeight": "31pt" },
      "$type": "typography",
      "$description": "兼容旧文档：映射到 Rich H2"
    },
    "headline-h3": {
      "$value": { "fontSize": "17pt", "fontWeight": 600, "lineHeight": "29pt" },
      "$type": "typography",
      "$description": "兼容旧文档：映射到 Rich H3"
    },
    "body-primary": {
      "$value": { "fontSize": "16px", "fontWeight": 400, "lineHeight": "1.69em" },
      "$type": "typography",
      "$description": "兼容旧文档：对话气泡正文"
    },
    "body-secondary": {
      "$value": { "fontSize": "14px", "fontWeight": 400, "lineHeight": "20px" },
      "$type": "typography",
      "$description": "辅助正文"
    },
    "callout": {
      "$value": { "fontSize": "16px", "fontWeight": 500, "lineHeight": "22px" },
      "$type": "typography",
      "$description": "按钮/强调文本"
    },
    "subhead": {
      "$value": { "fontSize": "14px", "fontWeight": 400, "lineHeight": "20px" },
      "$type": "typography",
      "$description": "副标题、列表项"
    },
    "footnote": {
      "$value": { "fontSize": "13px", "fontWeight": 400, "lineHeight": "18px" },
      "$type": "typography",
      "$description": "脚注、时间标签"
    },
    "caption-1": {
      "$value": { "fontSize": "12px", "fontWeight": 400, "lineHeight": "17px" },
      "$type": "typography",
      "$description": "说明、分组标题"
    },
    "caption-2": {
      "$value": { "fontSize": "11px", "fontWeight": 400, "lineHeight": "13px" },
      "$type": "typography",
      "$description": "极小说明"
    }
  }
}
