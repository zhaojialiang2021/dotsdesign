{
  "$schema": "https://dots.design/schemas/component.schema.json",
  "slug": "button",
  "name": "Button",
  "category": "action",
  "description": "触发即时任务的动作单元。Dots Button 继承 ReDs 的六档尺寸、宽度和场景规则，主色映射为 info 5，图底场景使用 ghost。",
  "props": {
    "variant": {
      "values": ["filled", "outline", "neutral", "ghost"],
      "default": "filled",
      "description": "视觉层级。filled 是唯一主操作；outline 是强调次级动作；neutral 用于空态、取消和弱操作；ghost 只用于图片、彩色或深色背景。"
    },
    "size": {
      "values": ["xLarge", "large", "medium", "small", "mini", "micro"],
      "default": "medium",
      "description": "xLarge 48px / large 44px / medium 36px / small 28px / mini 24px / micro 20px。xLarge 与 micro 仅限特定场景。"
    },
    "icon": {
      "values": ["none", "leading", "trailing", "only"],
      "default": "none",
      "description": "图标位置。only 是纯图标按钮，必须提供 aria-label；文字按钮默认不带图标。"
    },
    "fullWidth": {
      "values": [false, true],
      "default": false,
      "description": "是否占满父容器。只用于表单底部、固定操作栏和页面主 CTA。"
    },
    "selected": {
      "values": [false, true],
      "default": false,
      "description": "用于关注类按钮的已选中状态，例如 已关注 / 互相关注。选中后通常降低层级。"
    }
  },
  "states": ["default", "pressed", "disabled", "loading", "selected"],
  "constraints": [
    {
      "rule": "max_filled_per_view",
      "value": 1,
      "description": "同一视图最多一个 variant=filled 的主操作，避免主次失焦。"
    },
    {
      "rule": "copy_pattern",
      "value": "verb_object_or_verb",
      "description": "按钮文案必须短，优先使用 谓语+宾语 或 谓语，例如 立即查看、去看看、发送、关注。"
    },
    {
      "rule": "width_hugs_content_after_min_width",
      "value": true,
      "description": "短文案使用 min-width 居中；长文案宽度随内容增长，并保留对应尺寸的左右 padding。"
    },
    {
      "rule": "full_width_requires_main_flow",
      "value": true,
      "description": "fullWidth 只能用于表单底部、固定操作栏或页面主 CTA，不用于卡片内普通按钮。"
    },
    {
      "rule": "ghost_requires_visual_background",
      "value": true,
      "description": "ghost 只用于图片、彩色或深色背景；图底按钮不展示 disabled 态。"
    },
    {
      "rule": "icon_only_requires_aria_label",
      "value": true,
      "description": "icon=only 时必须提供 aria-label。"
    }
  ],
  "tokens": {
    "variant.filled.bg": "info-5",
    "variant.filled.fg": "bg-light",
    "variant.filled.border": "info-5",
    "variant.outline.bg": "transparent",
    "variant.outline.fg": "info-6",
    "variant.outline.border": "info-6",
    "variant.neutral.bg": "transparent",
    "variant.neutral.fg": "title",
    "variant.neutral.border": "separator-2",
    "variant.ghost.bg": "fill-c",
    "variant.ghost.fg": "bg-light",
    "variant.ghost.border": "separator-light-5",
    "state.disabled.bg": "disabled",
    "state.disabled.fg": "placeholder",
    "size.xLarge.height": "48px",
    "size.xLarge.min-width": "112px",
    "size.xLarge.padding-x": "space-7",
    "size.xLarge.font": "callout",
    "size.large.height": "44px",
    "size.large.min-width": "102px",
    "size.large.padding-x": "space-6",
    "size.large.font": "callout",
    "size.medium.height": "36px",
    "size.medium.min-width": "82px",
    "size.medium.padding-x": "space-5",
    "size.medium.font": "subhead",
    "size.small.height": "28px",
    "size.small.min-width": "63px",
    "size.small.padding-x": "space-3",
    "size.small.font": "footnote",
    "size.mini.height": "24px",
    "size.mini.min-width": "52px",
    "size.mini.padding-x": "space-2",
    "size.mini.font": "caption-1",
    "size.micro.height": "20px",
    "size.micro.min-width": "40px",
    "size.micro.padding-x": "space-2",
    "size.micro.font": "caption-2",
    "radius": "radius-full"
  },
  "haptics": {
    "pressed": "light"
  },
  "anatomy": [
    {
      "part": "container",
      "tokens": ["bg", "border", "radius-full", "height", "min-width", "padding-x"],
      "description": "承载视觉层级、尺寸、最小宽度和左右 padding；长文案时宽度 hug content。"
    },
    {
      "part": "label",
      "tokens": ["fg", "font"],
      "description": "按钮文案，必须短，优先 谓语+宾语 或 谓语。"
    },
    {
      "part": "icon",
      "tokens": ["paragraph"],
      "description": "可选图标。leading/trailing 与文字同色；only 形态必须有 aria-label。"
    }
  ],
  "doDont": {
    "do": [
      "表单底部使用 size=large + variant=filled + fullWidth=true。",
      "空态动作使用 size=medium + variant=neutral。",
      "卡片内按钮使用 small 或 mini，避免抢过卡片标题。",
      "图片或彩色背景上使用 filled 或 ghost，不使用低识别度描边按钮。"
    ],
    "dont": [
      "不要在同一视图放两个 variant=filled 的按钮。",
      "不要把小红书红 --primary 用作点点主按钮。",
      "不要在图底按钮上展示 disabled 态。",
      "不要让 xLarge 或 micro 成为默认尺寸。",
      "不要在 button 内嵌 button 或链接。"
    ]
  }
}
